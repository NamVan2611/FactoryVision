# ============================================================
# Smart Factory Vision Inspection System
# Environment Configuration Template
# ------------------------------------------------------------
# Copy this file to ".env" and adjust values for your machine.
#   Windows : copy .env.example .env
#   Linux   : cp .env.example .env
# ============================================================

# ---------- Application ----------
APP_NAME="Smart Factory Vision Inspection"
APP_ENV=development            # development | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- Database ----------
# DB_MODE controls which engine is used:
#   sqlite  -> uses DB_SQLITE_PATH (development, zero-config)
#   mssql   -> uses the MSSQL_* values below (production)
DB_MODE=sqlite
DB_SQLITE_PATH=database/factory.db

MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=SmartFactory
MSSQL_USER=sa
MSSQL_PASSWORD=YourStrong!Passw0rd
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# ---------- Security ----------
JWT_SECRET_KEY=change-this-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
API_KEY=dev-api-key-change-me

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,app://.

# ---------- MQTT ----------
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=smart-factory-backend
MQTT_KEEPALIVE=60

# ---------- TCP / PLC ----------
TCP_HOST=0.0.0.0
TCP_PORT=9000

# ---------- Vision Inspection ----------
INSPECTION_CONFIDENCE_THRESHOLD=0.75
IMAGES_CAPTURED_DIR=images/captured
IMAGES_PROCESSED_DIR=images/processed
IMAGES_DEFECTS_DIR=images/defects

# ---------- Logging ----------
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=logs
LOG_MAX_BYTES=10485760         # 10 MB per log file
LOG_BACKUP_COUNT=5
